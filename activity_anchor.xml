<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Anchor Mode"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place this phone at a known corner of the space.\nDo not move it once broadcasting starts."
        android:textSize="14sp"
        android:alpha="0.6"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Anchor ID"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerAnchorId"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnToggleBroadcast"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Start Broadcasting"
        android:textSize="15sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvAnchorStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stopped"
        android:textSize="14sp"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="@android:color/transparent"/>

</LinearLayout>
