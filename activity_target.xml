<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target Mode"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvTargetStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Idle — tap Start to begin streaming"
        android:textSize="13sp"
        android:alpha="0.6"
        android:layout_marginBottom="16dp"/>

    <!-- Anchor signal bars -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visible Anchors"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:alpha="0.5"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvAnchorList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scanning…"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:padding="12dp"
        android:background="@android:color/transparent"
        android:layout_marginBottom="20dp"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnStartTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Streaming"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnStopTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>

</LinearLayout>
